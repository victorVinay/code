{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=identity_db;Username=postgres;Password=postgres;Port=5432"
  },
  "Jwt": {
    "Secret": "your-super-secret-key-change-this-in-production-minimum-32-characters",
